{
  "name": "quiz-app",
  "version": "1.0.0",
  "description": "Full-Stack Quiz Application",
  "private": true,
  "scripts": {
    "client": "npm --prefix client start",
    "server": "npm --prefix server run dev",
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "build": "npm --prefix client run build",
    "start": "npm run build && npm --prefix server start",
    "install-all": "npm install && npm --prefix client install && npm --prefix server install"
  },
  "keywords": [
    "quiz",
    "full-stack",
    "react",
    "express",
    "mongodb"
  ],
  "devDependencies": {
    "concurrently": "^8.2.2",
    "cross-env": "^7.0.3"
  },
  "dependencies": {
    "framer-motion": "^12.38.0"
  }
}
